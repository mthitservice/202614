# ============================================
# SICHERES IMAGE - Non-Root User
# ============================================

FROM python:3.12-slim

LABEL maintainer="Michael Lindner"
LABEL security.nonroot="true"

# Dependencies als root installieren
WORKDIR /app
COPY req.txt .
RUN pip install --no-cache-dir -r req.txt

# Non-root User erstellen
# -r: System-User (keine Home-Dir, kein Login)
# -s /bin/false: Kein Shell-Zugriff
# -u 1001: Feste UID für Kubernetes-Kompatibilität
RUN useradd -r -s /bin/false -u 1001 appuser

# App-Dateien kopieren
COPY app.py .


# Besitzer ändern
RUN chown -R appuser:appuser /app

# ============================================
# AB HIER: Alles als non-root!
# ============================================
USER appuser

# Non-privileged Port (>1024)
EXPOSE 8080

# Healthcheck
HEALTHCHECK --interval=30s --timeout=3s \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8080/health')" || exit 1

CMD ["python", "app.py"]
